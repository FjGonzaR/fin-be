# Environment
APP_ENV=production

# Database — local Docker not used in production
DATABASE_URL=
# Use Supabase Supavisor session pooler (IPv4, port 5432) — NOT the direct host (db.*.supabase.co)
# which resolves to IPv6 and fails on platforms without IPv6 outbound.
# URL-encode special chars in password (e.g. ! → %21).
DIRECT_DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require


# Application
DEBUG=false
UPLOAD_DIR=./data/uploads

# CORS — space-separated or JSON list of allowed frontend origins
ALLOWED_ORIGINS=["https://finanzas.tudominio.com"]

# Auth — use a strong random secret in production
JWT_SECRET=<replace-with-strong-random-secret>
JWT_EXPIRE_MINUTES=480

# Supabase Storage
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_KEY=<service_role_key>
SUPABASE_BUCKET=source-files
SUPABASE_UPLOAD_PREFIX=uploads/prod


# LLM / OpenRouter
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=<key>
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_CONFIDENCE_THRESHOLD=0.70
